---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
---

<BaseLayout title="媒体库" path="/media">
  <Container class="py-16 sm:py-20">
    <h1 class="text-3xl sm:text-4xl font-heading font-bold text-text-primary mb-2">媒体库</h1>
    <p class="text-text-secondary mb-10">照片与视频集锦</p>

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
      {Array.from({ length: 12 }).map((_, i) => (
        <div class="aspect-square rounded-xl img-placeholder flex items-center justify-center card-hover cursor-pointer" key={i}>
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" class="text-primary-300">
            <rect x="3" y="3" width="18" height="18" rx="2" ry="2" />
            <circle cx="8.5" cy="8.5" r="1.5" />
            <polyline points="21 15 16 10 5 21" />
          </svg>
        </div>
      ))}
    </div>

    <div class="text-center mt-12 text-text-secondary/60">
      <p>媒体资料持续更新中，敬请期待。</p>
    </div>
  </Container>
</BaseLayout>
