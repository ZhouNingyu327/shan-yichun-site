---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import Tag from '@/components/ui/Tag.astro';
import { getCollection } from 'astro:content';
import { SITE } from '@/utils/constants';

const pageSize = 10;
const page = Number(Astro.url.searchParams.get('page')) || 1;
const tag = Astro.url.searchParams.get('tag');

let allPosts = (await getCollection('news'))
  .sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime());

if (tag) {
  allPosts = allPosts.filter((p) => p.data.tags.includes(tag));
}

const totalPages = Math.ceil(allPosts.length / pageSize);
const posts = allPosts.slice((page - 1) * pageSize, page * pageSize);

// Collect all tags
const allTags = [...new Set(allPosts.flatMap((p) => p.data.tags))];
---

<BaseLayout title={`最新动态${tag ? ` - ${tag}` : ''}`} path={`/news${tag ? `?tag=${tag}` : ''}`}>
  <Container class="py-16 sm:py-20">
    <div class="flex items-center justify-between mb-10">
      <h1 class="text-3xl sm:text-4xl font-heading font-bold text-text-primary">最新动态</h1>
      <a href="/rss.xml" class="text-sm text-primary-600 hover:text-primary-700 font-medium transition-colors">RSS</a>
    </div>

    <!-- Tags filter -->
    <div class="flex flex-wrap gap-2 mb-8">
      <a href="/news" class={`px-3 py-1.5 rounded-full text-sm font-medium transition-colors ${!tag ? 'bg-primary-600 text-white' : 'bg-primary-50 text-text-secondary hover:bg-primary-100'}`}>
        全部
      </a>
      {allTags.map((t) => (
        <a href={`/news?tag=${encodeURIComponent(t)}`} class={`px-3 py-1.5 rounded-full text-sm font-medium transition-colors ${tag === t ? 'bg-primary-600 text-white' : 'bg-primary-50 text-text-secondary hover:bg-primary-100'}`}>
          {t}
        </a>
      ))}
    </div>

    <!-- News list -->
    <div class="grid gap-6 md:grid-cols-2">
      {posts.map((post) => (
        <a href={`/news/${post.id}`} class="group">
          <article class="bg-white rounded-2xl border border-primary-100/30 p-6 h-full card-hover">
            <div class="flex items-center gap-2 mb-3">
              <span class="text-xs text-text-secondary">{new Date(post.data.publishDate).toLocaleDateString('zh-CN')}</span>
              <span class="text-xs text-text-secondary/40">·</span>
              <span class="text-xs text-text-secondary">{post.data.source}</span>
            </div>
            <h2 class="text-lg font-semibold text-text-primary group-hover:text-primary-600 transition-colors mb-2 line-clamp-2">
              {post.data.title}
            </h2>
            <p class="text-sm text-text-secondary leading-relaxed line-clamp-3">{post.data.summary}</p>
            <div class="flex flex-wrap gap-1.5 mt-4">
              {post.data.tags.map((t) => <Tag>{t}</Tag>)}
            </div>
          </article>
        </a>
      ))}
    </div>

    {posts.length === 0 && (
      <div class="text-center py-20 text-text-secondary">
        <p>暂无动态信息。</p>
      </div>
    )}

    <!-- Pagination -->
    {totalPages > 1 && (
      <div class="flex items-center justify-center gap-2 mt-10">
        {Array.from({ length: totalPages }, (_, i) => i + 1).map((p) => (
          <a
            href={tag ? `/news?tag=${encodeURIComponent(tag)}&page=${p}` : `/news?page=${p}`}
            class={`w-9 h-9 flex items-center justify-center rounded-lg text-sm font-medium transition-colors ${p === page ? 'bg-primary-600 text-white' : 'bg-white text-text-secondary hover:bg-primary-50 border border-primary-100/30'}`}
          >
            {p}
          </a>
        ))}
      </div>
    )}
  </Container>
</BaseLayout>
