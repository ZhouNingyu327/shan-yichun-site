---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import MusicCard from '@/components/sections/MusicCard.astro';
import { getCollection } from 'astro:content';

const allMusic = await getCollection('discography');
const albums = allMusic.filter((m) => m.data.type === 'album').sort((a, b) => new Date(b.data.releaseDate).getTime() - new Date(a.data.releaseDate).getTime());
// 专辑内曲目不显示在列表中，仅在专辑详情页内可点击进入
const albumOnlySlugs = [
  'ling-yi-zhong-da-an', 'yong-gan-e-du-track', 'ni-hao-kuai-le', 'tell-me',
  'shi-jiao', 'yu-hou-ri-ji', 'forever-in-you-track', 'kong-er', 'ni-ming-xing',
  'gray-turns-to-may', 'chun-mei-mei-track', 'xiang-ri-kui-chao-zhe-ye',
  'jia-ru-wo-men-hai-ai-zhe', 'wo-biao-shi-li-jie', 'hai-ni-mo-li',
  'wo-guan-bu-zhu-wo-zi-ji', 'zhu-yu', 'you-qu', 'duo-shao-de-guang-yin', 'hai-you-shen-me-geng-hao-de'
];
const singles = allMusic.filter((m) => m.data.type === 'single' && !albumOnlySlugs.includes(m.id)).sort((a, b) => new Date(b.data.releaseDate).getTime() - new Date(a.data.releaseDate).getTime());
const osts = allMusic.filter((m) => m.data.type === 'ost').sort((a, b) => new Date(b.data.releaseDate).getTime() - new Date(a.data.releaseDate).getTime());
const displayTotal = albums.length + singles.length + osts.length;
---

<BaseLayout title="音乐作品" path="/music">
  <Container class="py-16 sm:py-20">
    <h1 class="text-3xl sm:text-4xl font-heading font-bold text-text-primary mb-2">音乐作品</h1>
    <p class="text-text-secondary mb-10">共 {displayTotal} 首原唱作品</p>

    {albums.length > 0 && (
      <section class="mb-16">
        <h2 class="text-xl font-heading font-semibold text-text-primary mb-6 flex items-center gap-2">
          专辑 <span class="text-sm font-normal text-text-secondary">{albums.length}张</span>
        </h2>
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
          {albums.map((item) => <MusicCard item={item} />)}
        </div>
      </section>
    )}

    {singles.length > 0 && (
      <section class="mb-16">
        <h2 class="text-xl font-heading font-semibold text-text-primary mb-6 flex items-center gap-2">
          单曲 <span class="text-sm font-normal text-text-secondary">{singles.length}首</span>
        </h2>
        <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
          {singles.map((item) => <MusicCard item={item} />)}
        </div>
      </section>
    )}

    {osts.length > 0 && (
      <section>
        <h2 class="text-xl font-heading font-semibold text-text-primary mb-6 flex items-center gap-2">
          OST / 影视原声 <span class="text-sm font-normal text-text-secondary">{osts.length}首</span>
        </h2>
        <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
          {osts.map((item) => <MusicCard item={item} />)}
        </div>
      </section>
    )}
  </Container>
</BaseLayout>
