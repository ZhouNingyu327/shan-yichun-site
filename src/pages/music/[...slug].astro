---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import Tag from '@/components/ui/Tag.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const musicEntries = await getCollection('discography');
  return musicEntries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { data } = entry;

const typeLabels: Record<string, string> = {
  album: '专辑', single: '单曲', ost: 'OST',
};

const coverGradients: Record<string, string> = {
  album: 'from-purple-600 via-purple-500 to-indigo-600',
  single: 'from-purple-500 via-pink-500 to-rose-500',
  ost: 'from-indigo-500 via-purple-500 to-violet-500',
};

// Build a lookup from song title to slug for album track linking
// Prefer non-album entries so self-titled tracks don't point to the album itself
const allMusic = await getCollection('discography');
const titleToSlug: Record<string, string> = {};
for (const m of allMusic) {
  const existing = titleToSlug[m.data.title];
  // If a title maps to an album and we find a non-album version, use the non-album version
  if (!existing || (m.data.type !== 'album' && existing !== m.id)) {
    titleToSlug[m.data.title] = m.id;
  }
}

const musicSchema = {
  '@context': 'https://schema.org',
  '@type': data.type === 'album' ? 'MusicAlbum' : 'MusicRecording',
  name: data.title,
  byArtist: { '@type': 'MusicGroup', name: '单依纯' },
  datePublished: data.releaseDate.toISOString(),
  ...(data.tracks ? { numTracks: data.tracks.length } : {}),
};

// Build info items array
const infoItems: { label: string; value: string }[] = [];
if (data.type !== 'album' && data.source) {
  infoItems.push({ label: '出处', value: data.source });
}
if (data.lyricist) infoItems.push({ label: '作词', value: data.lyricist });
if (data.composer) infoItems.push({ label: '作曲', value: data.composer });
if (data.arranger) infoItems.push({ label: '编曲', value: data.arranger });
if (data.label) infoItems.push({ label: '唱片公司', value: data.label });
if (data.duration) infoItems.push({ label: '时长', value: data.duration });
---

<BaseLayout title={data.title} path={`/music/${entry.id}`}>
  <script type="application/ld+json" set:html={JSON.stringify(musicSchema)} />

  <!-- 歌词开幕动画 -->
  {data.lyric && (
    <div id="lyric-overlay" class="fixed inset-0 z-50 flex items-center justify-center bg-black/80 backdrop-blur-sm" style="view-transition-name: none;">
      <div class="text-center px-6 animate-fade-in-up">
        <p class="text-2xl sm:text-3xl md:text-4xl font-heading text-white/90 leading-relaxed italic tracking-wide">
          「{data.lyric}」
        </p>
        <p class="mt-6 text-sm text-white/40 tracking-widest">— 《{data.title}》</p>
        <div class="mt-10">
          <button id="enter-btn"
            class="px-8 py-2.5 rounded-full bg-white/10 text-white/70 border border-white/20 text-sm tracking-widest hover:bg-white/20 hover:text-white transition-all">
            进入
          </button>
        </div>
      </div>
    </div>
  )}

  <Container class="py-16 sm:py-20">
    <div class="grid md:grid-cols-2 gap-10 lg:gap-16 items-start">
      <!-- 封面 -->
      <div class="relative">
        <div class={`aspect-square rounded-3xl bg-gradient-to-br ${coverGradients[data.type] || coverGradients.single} flex items-center justify-center shadow-2xl shadow-purple-500/20 overflow-hidden`}>
          <img src={`/images/covers/${entry.id}.jpg`} alt={data.title}
            class="absolute inset-0 w-full h-full object-cover" loading="eager"
            onerror="this.style.display='none'" />
          <div class="absolute inset-0 bg-gradient-to-br from-black/30 to-black/10" />
          <div class="relative z-10 text-center px-8">
            <p class="text-white/20 text-7xl sm:text-8xl font-heading font-bold leading-none mb-2">
              {data.type === 'album' ? 'A' : data.type === 'ost' ? 'O' : 'S'}
            </p>
            <p class="text-white/90 text-xl sm:text-2xl font-heading font-bold leading-tight">{data.title}</p>
            {data.titleEn && <p class="text-white/50 text-sm mt-2 tracking-wider">{data.titleEn}</p>}
          </div>
        </div>
      </div>

      <!-- 信息区 -->
      <div>
        <div class="flex items-center gap-3 mb-4 flex-wrap">
          <Tag variant={data.type === 'album' ? 'primary' : 'accent'}>{typeLabels[data.type]}</Tag>
          <span class="text-sm text-text-secondary">{new Date(data.releaseDate).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
        </div>

        <h1 class="text-3xl sm:text-4xl font-heading font-bold text-text-primary mb-2">{data.title}</h1>
        {data.titleEn && <p class="text-base text-text-secondary mb-6">{data.titleEn}</p>}

        <!-- 歌曲信息卡片 -->
        {infoItems.length > 0 && (
          <div class="bg-white rounded-xl border border-primary-100/30 overflow-hidden mb-6">
            {infoItems.map((item, i) => (
              <div class={`flex items-start gap-3 px-5 py-3 ${i < infoItems.length - 1 ? 'border-b border-primary-100/30' : ''}`}>
                <span class="text-xs font-medium text-text-secondary/60 w-14 flex-shrink-0 pt-0.5">{item.label}</span>
                <span class="text-sm text-text-primary">{item.value}</span>
              </div>
            ))}
          </div>
        )}

        <!-- 正文介绍 -->
        <div class="text-sm text-text-secondary leading-relaxed">
          <slot />
        </div>

        <!-- 专辑曲目 — 可点击进入独立页面 -->
        {data.tracks && data.tracks.length > 0 && (
          <div class="mt-8">
            <h2 class="text-lg font-semibold text-text-primary mb-4 flex items-center gap-2">
              曲目列表 <span class="text-sm font-normal text-text-secondary">{data.tracks.length}首</span>
            </h2>
            <div class="bg-white rounded-xl border border-primary-100/30 overflow-hidden">
              {data.tracks.map((track, index) => {
                const trackSlug = titleToSlug[track.name];
                const trackContent = (
                  <Fragment>
                    <span class="text-sm font-medium text-text-secondary/60 w-7 text-right">{track.number}</span>
                    <span class="flex-1 text-sm font-medium">{track.name}</span>
                    {track.duration && <span class="text-xs text-text-secondary">{track.duration}</span>}
                  </Fragment>
                );
                if (trackSlug) {
                  return (
                    <a href={`/music/${trackSlug}`} class={`flex items-center gap-4 px-5 py-3.5 transition-colors hover:bg-primary-100/70 group ${index < data.tracks!.length - 1 ? 'border-b border-primary-100/30' : ''}`}>
                      <span class="text-sm font-medium text-text-secondary/60 w-7 text-right">{track.number}</span>
                      <span class="flex-1 text-sm font-medium text-text-primary group-hover:text-primary-600 transition-colors">{track.name}</span>
                      {track.duration && <span class="text-xs text-text-secondary">{track.duration}</span>}
                      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-primary-300 opacity-0 group-hover:opacity-100 transition-opacity flex-shrink-0"><path d="M9 18l6-6-6-6"/></svg>
                    </a>
                  );
                }
                return (
                  <div class={`flex items-center gap-4 px-5 py-3.5 ${index < data.tracks!.length - 1 ? 'border-b border-primary-100/30' : ''}`}>
                    <span class="text-sm font-medium text-text-secondary/60 w-7 text-right">{track.number}</span>
                    <span class="flex-1 text-sm text-text-primary font-medium">{track.name}</span>
                    {track.duration && <span class="text-xs text-text-secondary">{track.duration}</span>}
                  </div>
                );
              })}
            </div>
          </div>
        )}

        <!-- 收听链接 -->
        {data.platforms && data.platforms.length > 0 && (
          <div class="mt-8">
            <h3 class="text-sm font-semibold text-text-primary mb-3">收听平台</h3>
            <div class="flex flex-wrap gap-2">
              {data.platforms.map((platform) => (
                <a href={platform.url} target="_blank" rel="noopener noreferrer"
                  class="inline-flex items-center px-4 py-2 bg-primary-50 text-primary-700 rounded-full text-sm font-medium hover:bg-primary-100 transition-colors">
                  {platform.name}
                </a>
              ))}
            </div>
          </div>
        )}
      </div>
    </div>
  </Container>
</BaseLayout>

<script is:inline>
  const overlay = document.getElementById('lyric-overlay');
  const btn = document.getElementById('enter-btn');
  if (overlay && btn) {
    btn.addEventListener('click', function() {
      overlay.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
      overlay.style.opacity = '0';
      overlay.style.transform = 'scale(1.05)';
      setTimeout(function() { overlay.style.display = 'none'; }, 600);
    });
    overlay.addEventListener('click', function(e) {
      if (e.target === overlay) {
        overlay.style.transition = 'opacity 0.6s ease';
        overlay.style.opacity = '0';
        setTimeout(function() { overlay.style.display = 'none'; }, 600);
      }
    });
  }
</script>

<style is:global>
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in-up {
    animation: fadeInUp 0.8s ease-out forwards;
  }
</style>
