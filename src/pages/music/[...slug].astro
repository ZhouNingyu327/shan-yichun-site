---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import Tag from '@/components/ui/Tag.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const musicEntries = await getCollection('discography');
  return musicEntries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { data } = entry;

const typeLabels: Record<string, string> = {
  album: '专辑',
  single: '单曲',
  ost: 'OST',
};

const coverGradients: Record<string, string> = {
  album: 'from-purple-600 via-purple-500 to-indigo-600',
  single: 'from-purple-500 via-pink-500 to-rose-500',
  ost: 'from-indigo-500 via-purple-500 to-violet-500',
};

const musicSchema = {
  '@context': 'https://schema.org',
  '@type': data.type === 'album' ? 'MusicAlbum' : 'MusicRecording',
  name: data.title,
  byArtist: { '@type': 'MusicGroup', name: '单依纯' },
  datePublished: data.releaseDate.toISOString(),
  ...(data.tracks ? { numTracks: data.tracks.length } : {}),
};
---

<BaseLayout title={data.title} path={`/music/${entry.id}`}>
  <script type="application/ld+json" set:html={JSON.stringify(musicSchema)} />

  <!-- 歌词开幕动画 -->
  {data.lyric && (
    <div id="lyric-overlay" class="fixed inset-0 z-50 flex items-center justify-center bg-black/80 backdrop-blur-sm" style="view-transition-name: none;">
      <div class="text-center px-6 animate-fade-in-up">
        <p class="text-2xl sm:text-3xl md:text-4xl font-heading text-white/90 leading-relaxed italic tracking-wide">
          「{data.lyric}」
        </p>
        <p class="mt-6 text-sm text-white/40 tracking-widest">— 《{data.title}》</p>
        <div class="mt-10">
          <button
            id="enter-btn"
            class="px-8 py-2.5 rounded-full bg-white/10 text-white/70 border border-white/20 text-sm tracking-widest hover:bg-white/20 hover:text-white transition-all"
          >
            进入
          </button>
        </div>
      </div>
    </div>
  )}

  <Container class="py-16 sm:py-20">
    <div class="grid md:grid-cols-2 gap-10 lg:gap-16 items-start">
      <!-- 封面区域 -->
      <div class="relative">
        <div class={`aspect-square rounded-3xl bg-gradient-to-br ${coverGradients[data.type] || coverGradients.single} flex items-center justify-center shadow-2xl shadow-purple-500/20 overflow-hidden`}>
          <div class="absolute inset-0 bg-white/5 backdrop-blur-[1px]" />
          <div class="relative z-10 text-center px-8">
            <p class="text-white/20 text-7xl sm:text-8xl font-heading font-bold leading-none mb-2">
              {(data.type === 'album' ? 'A' : data.type === 'ost' ? 'O' : 'S')}
            </p>
            <p class="text-white/90 text-xl sm:text-2xl font-heading font-bold leading-tight">
              {data.title}
            </p>
            {data.titleEn && (
              <p class="text-white/50 text-sm mt-2 tracking-wider">{data.titleEn}</p>
            )}
            {data.lyric && (
              <p class="text-white/40 text-xs mt-4 italic border-t border-white/10 pt-4 max-w-xs mx-auto">
                「{data.lyric}」
              </p>
            )}
          </div>
        </div>
      </div>

      <!-- 信息区域 -->
      <div>
        <div class="flex items-center gap-3 mb-4 flex-wrap">
          <Tag variant={data.type === 'album' ? 'primary' : 'accent'}>
            {typeLabels[data.type]}
          </Tag>
          <span class="text-sm text-text-secondary">{new Date(data.releaseDate).getFullYear()}</span>
          {data.label && <span class="text-xs text-text-secondary/60">· {data.label}</span>}
        </div>

        <h1 class="text-3xl sm:text-4xl font-heading font-bold text-text-primary mb-2">{data.title}</h1>
        {data.titleEn && <p class="text-base text-text-secondary mb-4">{data.titleEn}</p>}

        <!-- 歌曲介绍 -->
        <div class="prose prose-gray max-w-none text-text-secondary leading-relaxed">
          <slot />
        </div>

        <!-- 专辑曲目列表 -->
        {data.tracks && data.tracks.length > 0 && (
          <div class="mt-8">
            <h2 class="text-lg font-semibold text-text-primary mb-4 flex items-center gap-2">
              曲目列表
              <span class="text-sm font-normal text-text-secondary">{data.tracks.length}首</span>
            </h2>
            <div class="bg-white rounded-xl border border-primary-100/30 overflow-hidden">
              {data.tracks.map((track, index) => (
                <div class={`flex items-center gap-4 px-5 py-3.5 transition-colors hover:bg-primary-50/50 ${index < data.tracks!.length - 1 ? 'border-b border-primary-100/30' : ''}`}>
                  <span class="text-sm font-medium text-text-secondary/60 w-7 text-right">{track.number}</span>
                  <span class="flex-1 text-sm text-text-primary font-medium">{track.name}</span>
                  {track.duration && <span class="text-xs text-text-secondary">{track.duration}</span>}
                </div>
              ))}
            </div>
          </div>
        )}

        <!-- 收听链接 -->
        {data.platforms && data.platforms.length > 0 && (
          <div class="mt-8">
            <h2 class="text-sm font-semibold text-text-primary mb-3">收听平台</h2>
            <div class="flex flex-wrap gap-2">
              {data.platforms.map((platform) => (
                <a href={platform.url} target="_blank" rel="noopener noreferrer"
                   class="inline-flex items-center px-4 py-2 bg-primary-50 text-primary-700 rounded-full text-sm font-medium hover:bg-primary-100 transition-colors">
                  {platform.name}
                </a>
              ))}
            </div>
          </div>
        )}
      </div>
    </div>
  </Container>
</BaseLayout>

<script is:inline>
  // 歌词开幕动画 — 点击"进入"后淡出
  const overlay = document.getElementById('lyric-overlay');
  const btn = document.getElementById('enter-btn');
  if (overlay && btn) {
    btn.addEventListener('click', function() {
      overlay.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
      overlay.style.opacity = '0';
      overlay.style.transform = 'scale(1.05)';
      setTimeout(function() {
        overlay.style.display = 'none';
      }, 600);
    });
    // 也支持点击空白区域关闭
    overlay.addEventListener('click', function(e) {
      if (e.target === overlay) {
        overlay.style.transition = 'opacity 0.6s ease';
        overlay.style.opacity = '0';
        setTimeout(function() {
          overlay.style.display = 'none';
        }, 600);
      }
    });
  }
</script>

<style is:global>
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in-up {
    animation: fadeInUp 0.8s ease-out forwards;
  }
</style>
