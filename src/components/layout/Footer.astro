---
import { NAV_ITEMS, SOCIAL_LINKS, SITE } from '@/utils/constants';
---

<footer class="bg-white border-t border-primary-100/50 mt-16">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Brand -->
      <div>
        <h3 class="text-lg font-heading font-bold text-primary-700 mb-3">{SITE.name} · {SITE.nameEn}</h3>
        <p class="text-sm text-text-secondary leading-relaxed">
          {SITE.description}
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="text-sm font-semibold text-text-primary uppercase tracking-wider mb-3">页面导航</h4>
        <ul class="space-y-2">
          {
            NAV_ITEMS.map((item) => (
              <li>
                <a href={item.href} class="text-sm text-text-secondary hover:text-primary-600 transition-colors">
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Social Links -->
      <div>
        <h4 class="text-sm font-semibold text-text-primary uppercase tracking-wider mb-3">关注单依纯</h4>
        <ul class="space-y-2">
          {
            SOCIAL_LINKS.map((link) => (
              <li>
                <a
                  href={link.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-sm text-text-secondary hover:text-primary-600 transition-colors"
                >
                  {link.name}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <div class="border-t border-primary-100/50 mt-8 pt-8 text-center">
      <p class="text-xs text-text-secondary/60 leading-relaxed">
        本站为粉丝非官方站点，内容仅供信息参考。
        <br />
        所有图片、音乐版权归原作者及所属公司所有。
      </p>
      <p class="text-xs text-text-secondary/40 mt-2">
        &copy; {new Date().getFullYear()} {SITE.nameEn}. All rights belong to their respective owners.
      </p>
    </div>
  </div>
</footer>
