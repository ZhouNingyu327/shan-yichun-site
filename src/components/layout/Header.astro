---
import { NAV_ITEMS, SITE } from '@/utils/constants';
import MobileMenu from './MobileMenu.astro';
---

<header class="sticky top-0 z-50 bg-white/80 backdrop-blur-md border-b border-primary-100/50">
  <nav class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 group">
        <span class="text-xl sm:text-2xl font-heading font-bold text-primary-700 group-hover:text-primary-500 transition-colors">
          {SITE.name}
        </span>
        <span class="hidden sm:inline text-sm text-text-secondary/60 font-light tracking-wide">
          · {SITE.nameEn}
        </span>
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center gap-1">
        {
          NAV_ITEMS.map((item) => (
            <a
              href={item.href}
              class="px-3 py-2 text-sm font-medium text-text-secondary hover:text-primary-600 hover:bg-primary-50 rounded-lg transition-colors"
            >
              {item.label}
            </a>
          ))
        }
      </div>

      <!-- Mobile Menu Button -->
      <MobileMenu />
    </div>
  </nav>
</header>
