---
import Container from '@/components/ui/Container.astro';
import Tag from '@/components/ui/Tag.astro';
import type { CollectionEntry } from 'astro:content';

export interface Props {
  posts: CollectionEntry<'news'>[];
}
const { posts } = Astro.props;
---

<section class="py-16 sm:py-20">
  <Container>
    <div class="flex items-center justify-between mb-10">
      <h2 class="text-2xl sm:text-3xl font-heading font-bold text-text-primary">最新动态</h2>
      <a href="/news" class="text-sm text-primary-600 hover:text-primary-700 font-medium transition-colors">
        查看全部 →
      </a>
    </div>

    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {
        posts.map((post) => (
          <a href={`/news/${post.id}`} class="group">
            <article class="bg-white rounded-2xl border border-primary-100/30 p-6 h-full card-hover">
              <div class="flex items-center gap-2 mb-3">
                <span class="text-xs text-text-secondary">
                  {new Date(post.data.publishDate).toLocaleDateString('zh-CN')}
                </span>
                <span class="text-xs text-text-secondary/40">·</span>
                <span class="text-xs text-text-secondary">{post.data.source}</span>
              </div>
              <h3 class="text-base font-semibold text-text-primary group-hover:text-primary-600 transition-colors mb-2 line-clamp-2">
                {post.data.title}
              </h3>
              <p class="text-sm text-text-secondary leading-relaxed line-clamp-3">
                {post.data.summary}
              </p>
              <div class="flex flex-wrap gap-1.5 mt-4">
                {post.data.tags.slice(0, 3).map((tag) => <Tag>{tag}</Tag>)}
              </div>
            </article>
          </a>
        ))
      }
    </div>
  </Container>
</section>
