---
import Container from '@/components/ui/Container.astro';
import Card from '@/components/ui/Card.astro';
import type { CollectionEntry } from 'astro:content';

export interface Props {
  items: CollectionEntry<'discography'>[];
}
const { items } = Astro.props;

const typeLabels: Record<string, string> = {
  album: '专辑',
  single: '单曲',
  ost: 'OST',
};
const typeVariants: Record<string, 'default' | 'primary' | 'accent'> = {
  album: 'primary',
  single: 'default',
  ost: 'accent',
};
---

<section class="py-16 sm:py-20 bg-white/50">
  <Container>
    <h2 class="text-2xl sm:text-3xl font-heading font-bold text-text-primary mb-10">音乐作品</h2>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        items.slice(0, 4).map((item) => (
          <a href={`/music/${item.id}`} class="group">
            <Card class="p-0">
              <div class="aspect-square img-placeholder flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" class="text-primary-300">
                  <path d="M9 18V5l12-2v13" />
                  <circle cx="6" cy="18" r="3" />
                  <circle cx="18" cy="16" r="3" />
                </svg>
              </div>
              <div class="p-4">
                <h3 class="font-semibold text-text-primary group-hover:text-primary-600 transition-colors line-clamp-1">
                  {item.data.title}
                </h3>
                <p class="text-xs text-text-secondary mt-1">
                  {new Date(item.data.releaseDate).getFullYear()} · {typeLabels[item.data.type] || item.data.type}
                </p>
              </div>
            </Card>
          </a>
        ))
      }
    </div>

    <div class="text-center mt-8">
      <a href="/music" class="inline-flex items-center text-sm font-medium text-primary-600 hover:text-primary-700 transition-colors">
        查看全部作品 →
      </a>
    </div>
  </Container>
</section>
